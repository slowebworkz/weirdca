{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "imports": {
    "#lib": "./lib/index.ts",
    "#lib/*": "./lib/*"
  },
  "exports": {
    "./*": "./src/*.tsx",
    "./components": "./src/components/index.ts",
    "./carousel": "./src/carousel/index.ts",
    "./typography": "./src/typography/index.ts",
    "./page": "./src/page/index.ts",
    "./layout": "./src/layout/index.ts"
  },
  "scripts": {
    "format": "prettier --config node_modules/@repo/prettier-config/base.yaml --write .",
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "19.2.14",
    "eslint": "^9.39.2",
    "type-fest": "^5.4.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0"
  }
}
