{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "format": "prettier --config node_modules/@repo/prettier-config/next.yaml --write .",
    "lint": "eslint",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@repo/messages": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18"
  },
  "imports": {
    "#lib": "./lib/index.ts",
    "#lib/*": "./lib/*.ts",
    "#fonts": "./lib/fonts/index.ts"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.2",
    "postcss": "^8.5.6",
    "typescript": "5.9.3"
  }
}
